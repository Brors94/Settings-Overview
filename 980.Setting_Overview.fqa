{"name":"980.Setting Overview","type":"com.fibaro.multilevelSensor","apiVersion":"1.3","initialProperties":{"viewLayout":{"$jason":{"body":{"header":{"style":{"height":"0"},"title":"quickApp_device_375"},"sections":{"items":[{"components":[{"name":"info_cpu","style":{"weight":"1.2"},"text":"info_cpu","type":"label","visible":true},{"style":{"weight":"0.5"},"type":"space"}],"style":{"weight":"1.2"},"type":"vertical"},{"components":[{"components":[{"name":"update","style":{"weight":"0.50"},"text":"Update","type":"switch","value":"false","visible":true},{"name":"button_ID_8_2","style":{"weight":"0.50"},"text":" ","type":"button","visible":false}],"style":{"weight":"1.2"},"type":"horizontal"},{"style":{"weight":"0.5"},"type":"space"}],"style":{"weight":"1.2"},"type":"vertical"},{"components":[{"name":"info_zwave","style":{"weight":"1.2"},"text":"info_zwave","type":"label","visible":true},{"style":{"weight":"0.5"},"type":"space"}],"style":{"weight":"1.2"},"type":"vertical"},{"components":[{"name":"info_localaccess","style":{"weight":"1.2"},"text":"info_localaccess","type":"label","visible":true},{"style":{"weight":"0.5"},"type":"space"}],"style":{"weight":"1.2"},"type":"vertical"},{"components":[{"name":"Info","style":{"weight":"1.2"},"text":"Info","type":"label","visible":true},{"style":{"weight":"0.5"},"type":"space"}],"style":{"weight":"1.2"},"type":"vertical"},{"components":[{"max":"100","min":"0","name":"led_brightness","style":{"weight":"1.2"},"text":"","type":"slider","visible":true},{"style":{"weight":"0.5"},"type":"space"}],"style":{"weight":"1.2"},"type":"vertical"},{"components":[{"name":"info_users","style":{"weight":"1.2"},"text":"info_users","type":"label","visible":true},{"style":{"weight":"0.5"},"type":"space"}],"style":{"weight":"1.2"},"type":"vertical"},{"components":[{"name":"info_installer","style":{"weight":"1.2"},"text":"info_installer","type":"label","visible":true},{"style":{"weight":"0.5"},"type":"space"}],"style":{"weight":"1.2"},"type":"vertical"},{"components":[{"name":"installer_access24h","style":{"weight":"1.2"},"text":"Grant Installer Access 24h","type":"switch","value":"false","visible":true},{"style":{"weight":"0.5"},"type":"space"}],"style":{"weight":"1.2"},"type":"vertical"},{"components":[{"name":"space","style":{"weight":"1.2"},"text":"space","type":"label","visible":true},{"style":{"weight":"0.5"},"type":"space"}],"style":{"weight":"1.2"},"type":"vertical"}]}},"head":{"title":"quickApp_device_375"}}},"uiView":[{"components":[{"name":"info_cpu","style":{"weight":"1.0"},"text":"info_cpu","type":"label","visible":true}],"style":{"weight":"1.0"},"type":"horizontal"},{"components":[{"eventBinding":{"onLongPressDown":[{"params":{"actionName":"UIAction","args":["onLongPressDown","update","$event.value"]},"type":"deviceAction"}],"onLongPressReleased":[{"params":{"actionName":"UIAction","args":["onLongPressReleased","update","$event.value"]},"type":"deviceAction"}],"onReleased":[{"params":{"actionName":"UIAction","args":["onReleased","update","$event.value"]},"type":"deviceAction"}]},"name":"update","style":{"weight":"0.50"},"text":"Update","type":"switch","value":"false","visible":true},{"eventBinding":{"onLongPressDown":[{"params":{"actionName":"UIAction","args":["onLongPressDown","button_ID_8_2"]},"type":"deviceAction"}],"onLongPressReleased":[{"params":{"actionName":"UIAction","args":["onLongPressReleased","button_ID_8_2"]},"type":"deviceAction"}],"onReleased":[{"params":{"actionName":"UIAction","args":["onReleased","button_ID_8_2"]},"type":"deviceAction"}]},"name":"button_ID_8_2","style":{"weight":"0.50"},"text":" ","type":"button","visible":false}],"style":{"weight":"1.0"},"type":"horizontal"},{"components":[{"name":"info_zwave","style":{"weight":"1.0"},"text":"info_zwave","type":"label","visible":true}],"style":{"weight":"1.0"},"type":"horizontal"},{"components":[{"name":"info_localaccess","style":{"weight":"1.0"},"text":"info_localaccess","type":"label","visible":true}],"style":{"weight":"1.0"},"type":"horizontal"},{"components":[{"name":"Info","style":{"weight":"1.0"},"text":"Info","type":"label","visible":true}],"style":{"weight":"1.0"},"type":"horizontal"},{"components":[{"eventBinding":{"onChanged":[{"params":{"actionName":"UIAction","args":["onChanged","led_brightness","$event.value"]},"type":"deviceAction"}]},"max":"100","min":"0","name":"led_brightness","style":{"weight":"1.0"},"text":"","type":"slider","visible":true}],"style":{"weight":"1.0"},"type":"horizontal"},{"components":[{"name":"info_users","style":{"weight":"1.0"},"text":"info_users","type":"label","visible":true}],"style":{"weight":"1.0"},"type":"horizontal"},{"components":[{"name":"info_installer","style":{"weight":"1.0"},"text":"info_installer","type":"label","visible":true}],"style":{"weight":"1.0"},"type":"horizontal"},{"components":[{"eventBinding":{"onLongPressDown":[{"params":{"actionName":"UIAction","args":["onLongPressDown","installer_access24h","$event.value"]},"type":"deviceAction"}],"onLongPressReleased":[{"params":{"actionName":"UIAction","args":["onLongPressReleased","installer_access24h","$event.value"]},"type":"deviceAction"}],"onReleased":[{"params":{"actionName":"UIAction","args":["onReleased","installer_access24h","$event.value"]},"type":"deviceAction"}]},"name":"installer_access24h","style":{"weight":"1.0"},"text":"Grant Installer Access 24h","type":"switch","value":"false","visible":true}],"style":{"weight":"1.0"},"type":"horizontal"},{"components":[{"name":"space","style":{"weight":"1.0"},"text":"space","type":"label","visible":true}],"style":{"weight":"1.0"},"type":"horizontal"}],"useUiView":false,"uiCallbacks":[{"callback":"update","eventType":"onReleased","name":"update"},{"callback":"update_ld","eventType":"onLongPressDown","name":"update"},{"callback":"update_lr","eventType":"onLongPressReleased","name":"update"},{"callback":"a","eventType":"onReleased","name":"button_ID_8_2"},{"callback":"","eventType":"onLongPressDown","name":"button_ID_8_2"},{"callback":"","eventType":"onLongPressReleased","name":"button_ID_8_2"},{"callback":"led_brightness","eventType":"onChanged","name":"led_brightness"},{"callback":"installer_access24h","eventType":"onReleased","name":"installer_access24h"},{"callback":"installer_access24h_ld","eventType":"onLongPressDown","name":"installer_access24h"},{"callback":"installer_access24h_lr","eventType":"onLongPressReleased","name":"installer_access24h"}],"quickAppVariables":[{"name":"Username","type":"password","value":"********"},{"name":"Password","type":"password","value":"********"}],"typeTemplateInitialized":true,"userDescription":""},"initialInterfaces":[],"files":[{"name":"main","isMain":true,"isOpen":true,"content":"-- MIT License\n--\n-- Copyright (c) 2026 Joachim Brørs Sommerfeld\n--\n-- Permission is hereby granted, free of charge, to any person obtaining a copy of this software and associated documentation files (the \"Software\"), to deal in the Software without restriction, including without limitation the rights to use, copy, modify, merge, publish, distribute, sublicense, and/or sell copies of the Software, and to permit persons to whom the Software is furnished to do so, subject to the following conditions:\n--\n-- The above copyright notice and this permission notice shall be included in all copies or substantial portions of the Software.\n--\n-- THE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM, OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE SOFTWARE.\n--\n-- (Source: opensource.org)\n\n--%%name:980.CPU Watch HC3\n--%%type:com.fibaro.multilevelSensor\n--%%manufacturer:JBS\n--%%model:HC3 CPU Monitor\n--%%description:Polls /diagnostics and displays CPU, memory and storage usage\n\n--%%u:{label=\"info_cpu\",text=\"Loading...\"}\n--%%u:{button=\"update\",text=\"Update\"}\n--%%u:{label=\"info_zwave\",text=\"Loading...\"}\n--%%u:{label=\"info_localaccess\",text=\"Loading...\"}\n--%%u:{label=\"Info\",text=\"Loading...\"}\n--%%u:{slider=\"led_brightness\",text=\"Hub LED Brightness\",min=0,max=100}\n--%%u:{label=\"info_users\",text=\"Loading...\"}\n--%%u:{label=\"info_installer\",text=\"Loading...\"}\n--%%u:{button=\"installer_access24h\",text=\"Grant Installer Access 24h\"}\n--%%u:{label=\"space\",text=\"\"}\n\n---@diagnostic disable\n\n\n\n--%%var:Username=\"\"\n--%%var:Password=\"\"\n\n\n--%%debug:true\n--%%desktop:true\n--%%offline:false\n\nlocal version = \"v1.2.5\"\nlocal revision_date = \"06/04/26 18:56:42\"\n\nlocal C_LABEL = \"#ff9933\"\nlocal C_VALUE = \"#99ff33\"\nlocal C_RED = \"#ff0000\"\nlocal C_GREEN = \"#00ff00\"\nlocal POLL_MS  = 20*1000\nlocal ZWAVE_POLL_MS = 60 * 60 * 1000\nlocal ZWAVE_STARTUP_DELAY_MS = 10 * 1000\nlocal STORAGE_KEYS = {\n  avgSnapshot = \"avg_snapshot\",\n  cpuHistory = \"cpu_history\",\n  prevCpu = \"prev_cpu\",\n  mobileDeviceMeta = \"mobile_device_meta\",\n}\n\n-- Rolling-average ring buffer\nlocal POLL_S   = POLL_MS / 1000\nlocal W_15M    = math.ceil(15 * 60 / POLL_S)       --   90 samples\nlocal W_30M    = math.ceil(30 * 60 / POLL_S)       --  180 samples\nlocal W_1H     = math.ceil(60 * 60 / POLL_S)       --  360 samples\nlocal W_1D     = math.ceil(24 * 60 * 60 / POLL_S)  -- 8640 samples\n\nlocal function rbNew(max)\n  return { data = {}, wp = 1, size = 0, max = max }\nend\n\nlocal function rbPush(rb, val)\n  rb.data[rb.wp] = val\n  rb.wp   = (rb.wp % rb.max) + 1\n  if rb.size < rb.max then rb.size = rb.size + 1 end\nend\n\n-- Returns average of the last `n` samples, or nil if ring is empty.\n-- When the ring has fewer than `n` samples the available ones are used\n-- and a \"(Xm)\" suffix string is returned as the second value.\nlocal function rbAvg(rb, n)\n  if rb.size == 0 then return nil, nil end\n  local count  = math.min(n, rb.size)\n  local sum    = 0\n  for i = 1, count do\n    local pos = ((rb.wp - 1 - i + rb.max * 2) % rb.max) + 1\n    sum = sum + rb.data[pos]\n  end\n  local avg    = sum / count\n  local suffix = (count < n) and string.format(\" (%dm)\", math.floor(count * POLL_S / 60)) or nil\n  return avg, suffix\nend\n\nlocal function toNum(v)\n  return tonumber(v) or 0\nend\n\nlocal function round1(v)\n  return math.floor(v * 10 + 0.5) / 10\nend\n\nlocal function cpuTotal(c)\n  return toNum(c.user) + toNum(c.system) + toNum(c.nice) + toNum(c.idle)\nend\n\nlocal function calcCpuPercent(prev, curr)\n  local deltaTotal = cpuTotal(curr) - cpuTotal(prev)\n  local deltaIdle  = toNum(curr.idle) - toNum(prev.idle)\n  if deltaTotal <= 0 then return 0 end\n  return ((deltaTotal - deltaIdle) / deltaTotal) * 100\nend\n\nlocal function escHtml(s)\n  s = tostring(s or \"\")\n  s = s:gsub(\"&\", \"&amp;\")\n  s = s:gsub(\"<\", \"&lt;\")\n  s = s:gsub(\">\", \"&gt;\")\n  return s\nend\n\nlocal SPACER = \"<tr><td colspan='2'>&nbsp;</td></tr>\"\nlocal SEPARATOR = \"<tr><td colspan='2'><hr style='border:1px solid #ff9933;'></td></tr>\"\n\nlocal function title(text)\n  return string.format(\n    \"<tr><td colspan='2' align='center'><font color='%s' size='4'><b>%s</b></font></td></tr>\",\n    C_LABEL, escHtml(text)\n  )\nend\n\nlocal function row(icon, name, value)\n  return string.format(\n    \"<tr><td width='50%%' align='left'>%s <font color='%s'>%s:</font></td><td width='50%%' align='right'><font color='%s'>%s</font></td></tr>\",\n    icon, C_LABEL, escHtml(name), C_VALUE, escHtml(value)\n  )\nend\n\nlocal C_LINK = \"#5599ff\"\n\nlocal function linkRow(icon, name, url, description)\n  local html = string.format(\n    \"<tr><td colspan='2' align='left'>%s <font color='%s'>%s:</font></td></tr>\"\n    .. \"<tr><td colspan='2' align='center'><a href='%s'><font color='%s' size='3'>%s</font></a></td></tr>\",\n    icon, C_LABEL, escHtml(name), escHtml(url), C_LINK, escHtml(url)\n  )\n  if description and description ~= \"\" then\n    html = html .. string.format(\n      \"<tr><td colspan='2' align='left'><font color='%s' size='2'><i>%s</i></font></td></tr>\",\n      C_LINK, escHtml(description)\n    )\n  end\n  return html\nend\n\nlocal function renderHtml(lines)\n  return \"<table width='400px' border='0' cellpadding='1' cellspacing='0'>\"\n    .. table.concat(lines, \"\")\n    .. \"</table>\"\nend\n\n-- Builds a small centered section header inside an info card.\nlocal function sectionTitle(text)\n  return string.format(\n    \"<tr><td colspan='2' align='center'><font color='%s' size='3'><b>%s</b></font></td></tr>\",\n    C_LABEL, escHtml(text)\n  )\nend\n\n-- Builds a left-aligned section header inside an info card.\nlocal function sectionTitleLeft(text)\n  return string.format(\n    \"<tr><td colspan='2' align='left'><font color='%s' size='3'><b>%s</b></font></td></tr>\",\n    C_LABEL, escHtml(text)\n  )\nend\n\n-- Formats a Unix timestamp in milliseconds for local UI display.\nlocal function formatUnixMs(timestampMs)\n  local value = tonumber(timestampMs)\n  if not value or value <= 0 then return \"n/a\" end\n  return os.date(\"%Y-%m-%d %H:%M:%S\", math.floor(value / 1000))\nend\n\n-- Returns the number of hours between two Unix timestamps in milliseconds.\nlocal function hoursBetweenUnixMs(fromMs, toMs)\n  local fromValue = tonumber(fromMs)\n  local toValue = tonumber(toMs)\n  if not fromValue or not toValue or toValue <= fromValue then return nil end\n  return (toValue - fromValue) / (1000 * 60 * 60)\nend\n\n-- Formats an hour span for compact UI display.\nlocal function formatHours(hours)\n  if not hours then return \"n/a\" end\n  return string.format(\"%.1fh\", hours)\nend\n\n-- Builds the Z-Wave transmission diagnostics panel shown in the QA UI.\nlocal function buildZwaveDiagnosticPanel(zwaveData)\n  local panel = { title(\"Z-Wave Diagnostic\") }\n  if type(zwaveData) ~= \"table\" then\n    panel[#panel + 1] = row(\"📡\", \"Transmissions\", \"n/a\")\n    return panel\n  end\n\n  panel[#panel + 1] = sectionTitle(\"Data\")\n  panel[#panel + 1] = row(\"🕒\", \"From\", formatUnixMs(zwaveData.since))\n  panel[#panel + 1] = row(\"🕒\", \"To\", formatUnixMs(zwaveData[\"until\"]))\n  local durationHours = hoursBetweenUnixMs(zwaveData.since, zwaveData[\"until\"])\n  panel[#panel + 1] = row(\"⏱️\", \"Duration\", formatHours(durationHours))\n  panel[#panel + 1] = SPACER\n  panel[#panel + 1] = sectionTitleLeft(\"Top 10\")\n  panel[#panel + 1] = row(\"\", \"nodeId\", \"incomingTotal\")\n\n  local items = {}\n  if type(zwaveData.items) == \"table\" then\n    for _, item in ipairs(zwaveData.items) do\n      items[#items + 1] = item\n    end\n  end\n\n  table.sort(items, function(a, b)\n    local incomingA = toNum(a and a.incomingTotal)\n    local incomingB = toNum(b and b.incomingTotal)\n    if incomingA == incomingB then\n      return toNum(a and a.nodeId) < toNum(b and b.nodeId)\n    end\n    return incomingA > incomingB\n  end)\n\n  if #items == 0 then\n    panel[#panel + 1] = row(\"📡\", \"Nodes\", \"n/a\")\n    return panel\n  end\n\n  for i = 1, math.min(10, #items) do\n    local item = items[i]\n    local incomingTotal = math.floor(toNum(item.incomingTotal))\n    local valueText = durationHours\n      and string.format(\"%.2f\", incomingTotal / durationHours)\n      or string.format(\"%d\", incomingTotal)\n    panel[#panel + 1] = row(\n      \"📶\",\n      \"Node \" .. tostring(item.nodeId or \"n/a\"),\n      valueText\n    )\n  end\n  return panel\nend\n\n-- Builds the Z-Wave status panel shown before data is available.\nlocal function buildZwavePendingPanel(statusText)\n  return {\n    title(\"Z-Wave Diagnostic\"),\n    row(\"📡\", \"Status\", tostring(statusText or \"Waiting for startup fetch...\"))\n  }\nend\n\nlocal function readStoredTable(self, key)\n  local raw = self:internalStorageGet(key)\n  if type(raw) == \"table\" then return raw end\n  if type(raw) ~= \"string\" or raw == \"\" then return nil end\n  local ok, decoded = pcall(json.decode, raw)\n  if ok and type(decoded) == \"table\" then return decoded end\n  return nil\nend\n\nfunction QuickApp:writeStoredTable(key, value)\n  local ok, encoded = pcall(json.encode, value)\n  if ok then self:internalStorageSet(key, encoded) end\nend\n\nlocal function sanitizeMobileDeviceDetail(deviceId, details)\n  if type(details) ~= \"table\" then return nil end\n  local props = type(details.properties) == \"table\" and details.properties or {}\n  local normalizedId = tonumber(details.id) or tonumber(deviceId) or deviceId\n  return {\n    id = normalizedId,\n    properties = {\n      appId = props.appId,\n      lastLoggedUser = props.lastLoggedUser,\n      system = props.system,\n    },\n  }\nend\n\nlocal function normalizeDeviceDetailsMap(deviceDetails)\n  local normalized = {}\n  if type(deviceDetails) ~= \"table\" then return normalized end\n  for deviceId, details in pairs(deviceDetails) do\n    local safeDetails = sanitizeMobileDeviceDetail(deviceId, details)\n    if safeDetails then\n      normalized[safeDetails.id] = safeDetails\n    end\n  end\n  return normalized\nend\n\nlocal function getStoredDeviceDetails(deviceDetails, deviceId)\n  if type(deviceDetails) ~= \"table\" then return nil end\n  return deviceDetails[deviceId] or deviceDetails[tostring(deviceId)]\nend\n\nlocal function restoreDeviceDetailsFromMeta(self)\n  local restored = {}\n  local meta = readStoredTable(self, STORAGE_KEYS.mobileDeviceMeta)\n  if type(meta) ~= \"table\" then return restored end\n  for _, item in ipairs(meta) do\n    local deviceId = tonumber(item.id) or item.id\n    if deviceId ~= nil then\n      restored[deviceId] = {\n        id = deviceId,\n        properties = {\n          appId = item.appType ~= \"n/a\" and item.appType or nil,\n          lastLoggedUser = item.lastLoggedUser,\n          system = item.system ~= \"n/a\" and item.system or nil,\n        },\n      }\n    end\n  end\n  return restored\nend\n\nlocal function buildMobileDeviceMeta(iosDevices, deviceDetails)\n  local meta = {}\n  if type(iosDevices) ~= \"table\" then return meta end\n\n  for _, device in ipairs(iosDevices) do\n    local details = getStoredDeviceDetails(deviceDetails, device.id)\n    local props = details and details.properties or nil\n    meta[#meta + 1] = {\n      id = (details and details.id) or device.id,\n      appType = (props and props.appId) or \"n/a\",\n      lastLoggedUser = (props and props.lastLoggedUser) or nil,\n      system = (props and props.system) or \"n/a\",\n    }\n  end\n  return meta\nend\n\nfunction QuickApp:saveMobileDeviceMeta()\n  local iosDevices = self.staticData and self.staticData.iosDevices or {}\n  local deviceDetails = self.staticData and self.staticData.deviceDetails or {}\n  local meta = buildMobileDeviceMeta(iosDevices, deviceDetails)\n  self:writeStoredTable(STORAGE_KEYS.mobileDeviceMeta, meta)\nend\n\nfunction QuickApp:saveStaticData()\n  local payload = {}\n  if type(self.staticData) == \"table\" then\n    for key, value in pairs(self.staticData) do\n      payload[key] = value\n    end\n    payload.deviceDetails = normalizeDeviceDetailsMap(self.staticData.deviceDetails)\n  end\n  local ok, encoded = pcall(json.encode, payload)\n  if ok then\n    self:internalStorageSet(\"staticData\", encoded)\n  end\n  self:saveMobileDeviceMeta()\nend\n\nfunction QuickApp:loadStaticData()\n  local raw = self:internalStorageGet(\"staticData\")\n  if type(raw) == \"string\" then\n    local ok, decoded = pcall(json.decode, raw)\n    if ok and type(decoded) == \"table\" then\n      decoded.deviceDetails = normalizeDeviceDetailsMap(decoded.deviceDetails)\n      if next(decoded.deviceDetails) == nil then\n        decoded.deviceDetails = restoreDeviceDetailsFromMeta(self)\n      end\n      self.staticData = decoded\n      return true\n    end\n  end\n  return false\nend\n\nlocal function restoreRingBuffer(saved)\n  local rb = rbNew(W_1D)\n  if type(saved) ~= \"table\" then return rb end\n\n  local data = type(saved.data) == \"table\" and saved.data or {}\n  local limit = math.min(#data, W_1D)\n  for i = 1, limit do\n    rb.data[i] = tonumber(data[i]) or 0\n  end\n\n  rb.wp = math.max(1, math.min(tonumber(saved.wp) or 1, W_1D))\n  rb.size = math.max(0, math.min(tonumber(saved.size) or 0, W_1D))\n  return rb\nend\n\nlocal function loadInstallerTimeline(self)\n  local raw = self:internalStorageGet(\"installerTimeline\")\n  if type(raw) ~= \"string\" or raw == \"\" then\n    return { grantedAt = nil, expiresAt = nil, withdrawnAt = nil }\n  end\n  local ok, decoded = pcall(json.decode, raw)\n  if not ok or type(decoded) ~= \"table\" then\n    return { grantedAt = nil, expiresAt = nil, withdrawnAt = nil }\n  end\n  return {\n    grantedAt = decoded.grantedAt,\n    expiresAt = decoded.expiresAt,\n    withdrawnAt = decoded.withdrawnAt,\n  }\nend\n\nlocal function saveInstallerTimeline(self)\n  local payload = {\n    grantedAt = self.installerGrantedAt,\n    expiresAt = self.installerExpiresAt,\n    withdrawnAt = self.installerWithdrawnAt,\n  }\n  local ok, encoded = pcall(json.encode, payload)\n  if ok then\n    self:internalStorageSet(\"installerTimeline\", encoded)\n  end\nend\n\nlocal function base64Encode(data)\n  local b='ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'\n  return ((data:gsub('.', function(x)\n    local r,bits='',''\n    local byte=string.byte(x)\n    for i=8,1,-1 do bits=bits..(math.floor(byte / 2^(i-1)) % 2) end\n    return bits\n  end)..'0000'):gsub('%d%d%d?%d?%d?%d?', function(x)\n    if #x < 6 then return '' end\n    local c=0\n    for i=1,6 do c=c + (x:sub(i,i)=='1' and 2^(6-i) or 0) end\n    return b:sub(c+1, c+1)\n  end)..({ '', '==', '=' })[#data % 3 + 1])\nend\n\nlocal function parseBoolFromEvent(event)\n  if type(event) ~= \"table\" or type(event.values) ~= \"table\" then\n    return nil\n  end\n  local raw = event.values[1]\n  if type(raw) == \"boolean\" then\n    return raw\n  end\n  local normalized = tostring(raw or \"\"):lower()\n  if normalized == \"true\" or normalized == \"1\" or normalized == \"on\" then\n    return true\n  end\n  if normalized == \"false\" or normalized == \"0\" or normalized == \"off\" then\n    return false\n  end\n  return nil\nend\n\nlocal function setInstallerAccessButtonText(self, enabled)\n  local installerStatus = enabled and \"✅ true\" or \"❌ false\"\n  self:updateView(\"installer_access24h\", \"text\", string.format(\"Installer Remote Access (%s)\", installerStatus))\nend\n\nlocal function setInstallerAccessButtonValue(self, enabled)\n  self:updateView(\"installer_access24h\", \"value\", enabled and \"true\" or \"false\")\nend\n\nlocal function refreshInstallerAccessButton(self, enabled)\n  setInstallerAccessButtonText(self, enabled)\n  setInstallerAccessButtonValue(self, enabled)\nend\n\nlocal function refreshLedBrightnessSlider(self, brightness)\n  self:updateView(\"led_brightness\", \"value\", tostring(toNum(brightness)))\nend\n\nlocal function syncInstallationAccessState(self, newEnabled, now)\n  local ok, res = pcall(function()\n    return api.put(\"/settings/installationAccess\", {\n      installationAccess = newEnabled,\n      installationAccessExpireTime = newEnabled and (now + 24 * 3600) or 0,\n    })\n  end)\n  if not ok then\n    self:debug(\"Could not sync settings/installationAccess (error): \" .. tostring(res))\n    return false\n  end\n  self:debug(\"settings/installationAccess sync succeeded\")\n  return true\nend\n\nlocal function requestInstallerAccessWithAdmin(self, newEnabled, previousEnabled)\n  local adminUser = tostring(self:getVariable(\"Username\") or \"\")\n  local adminPassword = tostring(self:getVariable(\"Password\") or \"\")\n  if adminUser == \"\" or adminPassword == \"\" then\n    self:error(\"Admin credentials not set (Username/Password)\")\n    setInstallerAccessButtonValue(self, previousEnabled)\n    return false\n  end\n\n  local authHeader = \"Basic \" .. base64Encode(adminUser .. \":\" .. adminPassword)\n  self.http = self.http or net.HTTPClient()\n  local options = {\n    options = {\n      method = \"PUT\",\n      headers = {\n        [\"Content-Type\"] = \"application/json\",\n        [\"Authorization\"] = authHeader,\n      },\n      checkCertificate = true,\n    },\n    data = json.encode({ remoteAccess = newEnabled }),\n    success = function(resp)\n      self:debug(\"Installer access set via admin auth, status\", tostring(resp.status))\n      if resp.status == 200 or resp.status == 204 then\n        self.installerInfo = self.installerInfo or {}\n        self.installerInfo.remoteAccess = newEnabled\n        local now = os.time()\n        if newEnabled then\n          self.installerGrantedAt = now\n          self.installerExpiresAt = now + 24 * 3600\n          self.installerWithdrawnAt = nil\n        else\n          self.installerWithdrawnAt = now\n          self.installerExpiresAt = nil\n        end\n        saveInstallerTimeline(self)\n        self.credentialError = false  -- success\n        syncInstallationAccessState(self, newEnabled, now)\n        setInstallerAccessButtonText(self, newEnabled)\n        setTimeout(function() self:pollDiagnostics() end, 2000)\n      else\n        self:error(\"Admin installer access request failed, status \" .. tostring(resp.status))\n        self.credentialError = true  -- error\n        setInstallerAccessButtonValue(self, previousEnabled)\n      end\n    end,\n    error = function(err)\n      self:error(\"Admin installer access HTTP error: \" .. tostring(err))\n      self.credentialError = true  -- error\n      setInstallerAccessButtonValue(self, previousEnabled)\n    end,\n  }\n\n  local url = \"https://127.0.0.1/installer\"\n  self.http:request(url, options)\n  return true\nend\n\nlocal function avgText(value, suffix)\n  return string.format(\"%.1f%%%s\", round1(value), suffix or \"\")\nend\n\nlocal function buildAvgSnapshot(self, avgPct)\n  local avg15, s15 = rbAvg(self.cpuHistory, W_15M)\n  local avg30, s30 = rbAvg(self.cpuHistory, W_30M)\n  local avg1h, s1h = rbAvg(self.cpuHistory, W_1H)\n  local avg1d, s1d = rbAvg(self.cpuHistory, W_1D)\n  return {\n    cpuAvg = avgPct,\n    avg15 = avg15, avg15Sfx = s15,\n    avg30 = avg30, avg30Sfx = s30,\n    avg1h = avg1h, avg1hSfx = s1h,\n    avg1d = avg1d, avg1dSfx = s1d,\n  }\nend\n\nlocal function buildAvgRows(snapshot)\n  local rows = {}\n  if type(snapshot) ~= \"table\" then return rows end\n\n  if tonumber(snapshot.cpuAvg) then\n    rows[#rows + 1] = row(\"📊\", \"CPU avg\", avgText(snapshot.cpuAvg))\n  end\n  if tonumber(snapshot.avg15) then\n    rows[#rows + 1] = row(\"📈\", \"15m avg\", avgText(snapshot.avg15, snapshot.avg15Sfx))\n  end\n  if tonumber(snapshot.avg30) then\n    rows[#rows + 1] = row(\"📈\", \"30m avg\", avgText(snapshot.avg30, snapshot.avg30Sfx))\n  end\n  if tonumber(snapshot.avg1h) then\n    rows[#rows + 1] = row(\"📈\", \"1h avg\", avgText(snapshot.avg1h, snapshot.avg1hSfx))\n  end\n  if tonumber(snapshot.avg1d) then\n    rows[#rows + 1] = row(\"📈\", \"24h avg\", avgText(snapshot.avg1d, snapshot.avg1dSfx))\n  end\n  return rows\nend\n\nlocal function persistCpuState(self)\n  self:writeStoredTable(STORAGE_KEYS.prevCpu, self.prevCpu or {})\n  self:writeStoredTable(STORAGE_KEYS.avgSnapshot, self.avgSnapshot or {})\n  self:writeStoredTable(STORAGE_KEYS.cpuHistory, {\n    data = self.cpuHistory and self.cpuHistory.data or {},\n    wp = self.cpuHistory and self.cpuHistory.wp or 1,\n    size = self.cpuHistory and self.cpuHistory.size or 0,\n  })\nend\n\nlocal function sampleThisQaCpu(self)\n  local nowCpu = os.clock()\n  local nowWall = os.time()\n\n  if not self.prevQaCpuClock or not self.prevQaWallTime then\n    self.prevQaCpuClock = nowCpu\n    self.prevQaWallTime = nowWall\n    return nil\n  end\n\n  local deltaWall = nowWall - self.prevQaWallTime\n  local deltaCpu = nowCpu - self.prevQaCpuClock\n  self.prevQaCpuClock = nowCpu\n  self.prevQaWallTime = nowWall\n\n  if deltaWall <= 0 then return nil end\n  return math.max(0, (deltaCpu / deltaWall) * 100)\nend\n\nlocal function fetchMobileDeviceDetails(self, devices)\n  if type(devices) ~= \"table\" then return end\n  self.staticData = self.staticData or {}\n  self.staticData.deviceDetails = self.staticData.deviceDetails or {}\n\n  for _, device in ipairs(devices) do\n    local ok, dev = pcall(function() return api.get(\"/devices/\" .. device.id) end)\n    if ok and type(dev) == \"table\" then\n      self.staticData.deviceDetails[device.id] = sanitizeMobileDeviceDetail(device.id, dev)\n    end\n  end\n\n  self:saveStaticData()\nend\n\nfunction QuickApp:fetchStaticData(stagger, startupDelayDeviceDetails)\n  local data = {}\n  if not stagger then\n    -- Synchronous calls for startup and button\n    local ok2, info = pcall(function() return api.get(\"/settings/info\") end)\n    if ok2 and type(info) == \"table\" then\n      data.settingsInfo = info\n    end\n\n    local ok3, led = pcall(function() return api.get(\"/settings/led\") end)\n    if ok3 and type(led) == \"table\" then\n      data.ledBrightness = led.brightness\n      refreshLedBrightnessSlider(self, led.brightness)\n    end\n\n    local ok4, net = pcall(function() return api.get(\"/settings/network\") end)\n    if ok4 and type(net) == \"table\" then\n      data.networkConfig = net.networkConfig\n    end\n\n    local ok5, users = pcall(function() return api.get(\"/users?includeInstaller=true\") end)\n    if ok5 and type(users) == \"table\" then\n      data.users = users\n    end\n\n    local ok6, instAccess = pcall(function() return api.get(\"/settings/installationAccess\") end)\n    if ok6 and type(instAccess) == \"table\" then\n      data.installerAccess = instAccess\n    end\n\n    local ok7, installerInfo = pcall(function() return api.get(\"/installer\") end)\n    if ok7 and type(installerInfo) == \"table\" then\n      data.installerInfo = installerInfo\n      self.installerInfo = installerInfo\n    else\n      self.installerInfo = self.installerInfo or nil\n    end\n\n    local iosDevicesList = nil\n    local ok8, iosDevices = pcall(function() return api.get(\"/iosDevices\") end)\n    if ok8 and type(iosDevices) == \"table\" then\n      iosDevicesList = iosDevices\n      data.iosDevices = iosDevices\n      data.deviceDetails = {}\n      if not startupDelayDeviceDetails then\n        for _, device in ipairs(iosDevices) do\n          local ok, dev = pcall(function() return api.get(\"/devices/\" .. device.id) end)\n          if ok and type(dev) == \"table\" then\n            data.deviceDetails[device.id] = sanitizeMobileDeviceDetail(device.id, dev)\n          end\n        end\n      end\n    end\n\n    self.staticData = data\n    self:saveStaticData()\n\n    if startupDelayDeviceDetails and iosDevicesList and #iosDevicesList > 0 then\n      setTimeout(function()\n        self:debug(\"Startup delayed fetch: /devices/{id} for mobile devices\")\n        fetchMobileDeviceDetails(self, iosDevicesList)\n        self:pollDiagnostics()\n      end, 10000)\n    end\n  else\n    -- Staggered calls for midnight refresh\n    local fetchSettings, fetchLed, fetchNetwork, fetchUsers, fetchInstAccess, fetchInstallerInfo, fetchIosDevices\n\n    fetchSettings = function()\n      local ok, info = pcall(function() return api.get(\"/settings/info\") end)\n      if ok and type(info) == \"table\" then data.settingsInfo = info end\n      setTimeout(function() fetchLed() end, 5000)\n    end\n\n    fetchLed = function()\n      local ok, led = pcall(function() return api.get(\"/settings/led\") end)\n      if ok and type(led) == \"table\" then\n        data.ledBrightness = led.brightness\n        refreshLedBrightnessSlider(self, led.brightness)\n      end\n      setTimeout(function() fetchNetwork() end, 5000)\n    end\n\n    fetchNetwork = function()\n      local ok, net = pcall(function() return api.get(\"/settings/network\") end)\n      if ok and type(net) == \"table\" then data.networkConfig = net.networkConfig end\n      setTimeout(function() fetchUsers() end, 5000)\n    end\n\n    fetchUsers = function()\n      local ok, users = pcall(function() return api.get(\"/users?includeInstaller=true\") end)\n      if ok and type(users) == \"table\" then data.users = users end\n      setTimeout(function() fetchInstAccess() end, 5000)\n    end\n\n    fetchInstAccess = function()\n      local ok, instAccess = pcall(function() return api.get(\"/settings/installationAccess\") end)\n      if ok and type(instAccess) == \"table\" then data.installerAccess = instAccess end\n      setTimeout(function() fetchInstallerInfo() end, 5000)\n    end\n\n    fetchInstallerInfo = function()\n      local ok, installerInfo = pcall(function() return api.get(\"/installer\") end)\n      if ok and type(installerInfo) == \"table\" then\n        data.installerInfo = installerInfo\n        self.installerInfo = installerInfo\n      else\n        self.installerInfo = self.installerInfo or nil\n      end\n      setTimeout(function() fetchIosDevices() end, 5000)\n    end\n\n    fetchIosDevices = function()\n      local ok, iosDevices = pcall(function() return api.get(\"/iosDevices\") end)\n      if ok and type(iosDevices) == \"table\" then\n        data.iosDevices = iosDevices\n        data.deviceDetails = {}\n        local devices = iosDevices\n        local function fetchDeviceDetail(i)\n          if i > #devices then\n            self.staticData = data\n            self:saveStaticData()\n            return\n          end\n          local device = devices[i]\n          local ok, dev = pcall(function() return api.get(\"/devices/\" .. device.id) end)\n          if ok and type(dev) == \"table\" then\n            data.deviceDetails[device.id] = sanitizeMobileDeviceDetail(device.id, dev)\n          end\n          setTimeout(function() fetchDeviceDetail(i+1) end, 5000)\n        end\n        if #devices > 0 then\n          fetchDeviceDetail(1)\n        else\n          self.staticData = data\n          self:saveStaticData()\n        end\n      else\n        self.staticData = data\n        self:saveStaticData()\n      end\n    end\n\n    fetchSettings()\n  end\nend\n\n-- =========================================================\n-- -------Staggered API Refresh for All APIs---------\n-- =========================================================\nfunction QuickApp:fetchAllApis()\n  self:debug(\"Refreshing all APIs with 5s stagger between calls\")\n  self:fetchStaticData(true)\nend\n\n-- Refreshes only the dedicated Z-Wave diagnostics label.\nfunction QuickApp:updateZwaveDiagnosticLabel()\n  local panel = type(self.zwaveTransmissions) == \"table\"\n    and buildZwaveDiagnosticPanel(self.zwaveTransmissions)\n    or buildZwavePendingPanel(self.zwaveStatusText)\n  self:updateView(\"info_zwave\", \"text\", renderHtml(panel))\nend\n\n-- Reads Z-Wave transmissions and refreshes the dedicated diagnostics card.\nfunction QuickApp:fetchZwaveTransmissions()\n  local username = tostring(self:getVariable(\"Username\") or \"\")\n  local password = tostring(self:getVariable(\"Password\") or \"\")\n  if username == \"\" or password == \"\" then\n    self.zwaveStatusText = \"Missing Username/Password\"\n    self:updateZwaveDiagnosticLabel()\n    self:warning(\"Failed to read /api/zwave/nodes/diagnostics/transmissions: missing Username/Password\")\n    return\n  end\n\n  local authHeader = \"Basic \" .. base64Encode(username .. \":\" .. password)\n  self.zwaveHttp = self.zwaveHttp or net.HTTPClient()\n  self.zwaveHttp:request(\"https://127.0.0.1/api/zwave/nodes/diagnostics/transmissions\", {\n    options = {\n      method = \"GET\",\n      headers = {\n        [\"accept\"] = \"application/json\",\n        [\"X-Fibaro-Version\"] = \"2\",\n        [\"Accept-language\"] = \"en\",\n        [\"Authorization\"] = authHeader,\n      },\n      checkCertificate = false,\n    },\n    success = function(response)\n      if response.status ~= 200 then\n        self.zwaveStatusText = \"HTTP \" .. tostring(response.status)\n        self:updateZwaveDiagnosticLabel()\n        self:warning(\"Failed to read /api/zwave/nodes/diagnostics/transmissions, status \" .. tostring(response.status))\n        return\n      end\n\n      local ok, decoded = pcall(json.decode, response.data or \"\")\n      if not ok or type(decoded) ~= \"table\" then\n        self.zwaveStatusText = \"Invalid JSON response\"\n        self:updateZwaveDiagnosticLabel()\n        self:warning(\"Failed to decode /api/zwave/nodes/diagnostics/transmissions response\")\n        return\n      end\n\n      self.zwaveStatusText = nil\n      self.zwaveTransmissions = decoded\n      if self.currentData then\n        self.currentData.zwaveTransmissions = decoded\n      end\n      self:updateZwaveDiagnosticLabel()\n    end,\n    error = function(err)\n      self.zwaveStatusText = \"HTTP request failed\"\n      self:updateZwaveDiagnosticLabel()\n      self:warning(\"Failed to read /api/zwave/nodes/diagnostics/transmissions: \" .. tostring(err))\n    end,\n  })\nend\n\n-- Schedules the next Z-Wave transmissions refresh.\nfunction QuickApp:scheduleZwaveRefresh(delayMs)\n  setTimeout(function()\n    self:fetchZwaveTransmissions()\n    self:scheduleZwaveRefresh(ZWAVE_POLL_MS)\n  end, delayMs or ZWAVE_POLL_MS)\nend\n\nfunction QuickApp:onInit()\n  self.prevCpu = readStoredTable(self, STORAGE_KEYS.prevCpu)\n  if type(self.prevCpu) ~= \"table\" or #self.prevCpu == 0 then self.prevCpu = nil end\n  self.avgSnapshot = readStoredTable(self, STORAGE_KEYS.avgSnapshot) or {}\n  self.cpuHistory = restoreRingBuffer(readStoredTable(self, STORAGE_KEYS.cpuHistory))\n\n  local installerTimeline = loadInstallerTimeline(self)\n  self.installerGrantedAt = installerTimeline.grantedAt\n  self.installerExpiresAt = installerTimeline.expiresAt\n  self.installerWithdrawnAt = installerTimeline.withdrawnAt\n\n  self.credentialError = false  -- flag for credential issues\n  self.updateInProgress = false\n\n  self.prevQaCpuClock = os.clock()\n  self.prevQaWallTime = os.time()\n  self:updateProperty(\"unit\", \"%\")\n  self:debug(\"HC3 CPU Watch started — property: Avg cpu %\")\n  self:updateView(\"update\", \"text\", \"Update\")\n  self:updateView(\"update\", \"value\", \"false\")\n  self:updateView(\"info_zwave\", \"text\", renderHtml(buildZwavePendingPanel()))\n  self:updateView(\"installer_access24h\", \"value\", \"false\")\n  self:loadStaticData()\n  if self.staticData and self.staticData.ledBrightness ~= nil then\n    refreshLedBrightnessSlider(self, self.staticData.ledBrightness)\n  end\n  self:pollDiagnostics()\n  if not self.staticData then\n    self:fetchStaticData(false, true)\n  end\n  self:scheduleZwaveRefresh(ZWAVE_STARTUP_DELAY_MS)\n  self:scheduleMidnightRefresh()\nend\n\nfunction QuickApp:scheduleMidnightRefresh()\n  local now = os.time()\n  local t = os.date(\"*t\", now)\n  t.hour, t.min, t.sec = 0, 0, 30\n  local midnight30 = os.time(t)\n  if midnight30 <= now then\n    midnight30 = midnight30 + 24 * 60 * 60\n  end\n  local delayMs = (midnight30 - now) * 1000\n  setTimeout(function()\n    self:debug(\"Midnight refresh — updating settings info\")\n    local ok, info = pcall(function() return api.get(\"/settings/info\") end)\n    if ok and type(info) == \"table\" then\n      self:debug(string.format(\"Sunrise: %s, Sunset: %s\", tostring(info.sunriseHour), tostring(info.sunsetHour)))\n    end\n    self:fetchStaticData(true)\n    self:scheduleMidnightRefresh()\n  end, delayMs)\n  self:debug(string.format(\"Next midnight refresh in %.0f min\", delayMs / 60000))\nend\n\nfunction QuickApp:buildInfoPanel(data)\n  local infoPanel = {}\n  infoPanel[#infoPanel + 1] = title(\"Settings\")\n\n  local info = data.settingsInfo\n  if not info then\n    infoPanel[#infoPanel + 1] = row(\"🏠\", \"HC3 Info\", \"n/a\")\n  else\n    infoPanel[#infoPanel + 1] = row(\"🏷️\", \"Hub Name\", tostring(info.hcName or \"n/a\"))\n    infoPanel[#infoPanel + 1] = row(\"🏠\", \"Platform\", tostring(info.platform or \"n/a\"))\n    infoPanel[#infoPanel + 1] = row(\"🏠\", \"Serial Nr\", tostring(info.serialNumber or \"n/a\"))\n    infoPanel[#infoPanel + 1] = row(\"🏠\", \"MAC\", tostring(info.mac or \"n/a\"))\n    infoPanel[#infoPanel + 1] = row(\"📡\", \"Zigbee\", tostring(info.zigbeeStatus or false))\n    infoPanel[#infoPanel + 1] = row(\"🌍\", \"Online\", tostring(info.online or false))\n    local tzHours = (tonumber(info.timezoneOffset) or 0) / 3600\n    infoPanel[#infoPanel + 1] = row(\"🕐\", \"Timezone\", string.format(\"UTC%+.0f\", tzHours))\n    infoPanel[#infoPanel + 1] = row(\"🏠\", \"Z-Wave Engine\", tostring(info.zwaveEngineVersion or \"n/a\"))\n    infoPanel[#infoPanel + 1] = row(\"🏠\", \"Z-Wave Version\", tostring(info.zwaveVersion or \"n/a\"))\n    infoPanel[#infoPanel + 1] = row(\"🏠\", \"Z-Wave Region\", tostring(info.zwaveRegion or \"n/a\"))\n    infoPanel[#infoPanel + 1] = row(\"🌐\", \"Language\", tostring(info.defaultLanguage or \"n/a\"))\n    infoPanel[#infoPanel + 1] = row(\"🌅\", \"Sunrise\", tostring(info.sunriseHour or \"n/a\"))\n    infoPanel[#infoPanel + 1] = row(\"🌇\", \"Sunset\", tostring(info.sunsetHour or \"n/a\"))\n    infoPanel[#infoPanel + 1] = row(\"🌡️\", \"Temp Unit\", tostring(info.temperatureUnit or \"n/a\"))\n    infoPanel[#infoPanel + 1] = row(\"🕐\", \"Time Format\", tostring(info.timeFormat or \"n/a\"))\n    infoPanel[#infoPanel + 1] = row(\"💰\", \"Currency\", tostring(info.currency or \"n/a\"))\n    infoPanel[#infoPanel + 1] = row(\"📦\", \"Software\", tostring(info.softVersion or \"n/a\"))\n    infoPanel[#infoPanel + 1] = row(\"🧪\", \"Running Beta\", tostring(info.beta or false))\n    infoPanel[#infoPanel + 1] = row(\"🎨\", \"Skin\", tostring(info.skin or \"n/a\"))\n    infoPanel[#infoPanel + 1] = row(\"🎨\", \"Skin Setting\", tostring(info.skinSetting or \"n/a\"))\n    infoPanel[#infoPanel + 1] = row(\"🔄\", \"Stable Update\", tostring(info.updateStableAvailable or false))\n    infoPanel[#infoPanel + 1] = row(\"🔄\", \"New Beta Available\", tostring(info.updateBetaAvailable or false))\n    infoPanel[#infoPanel + 1] = row(\"📦\", \"Newest Stable\", tostring(info.newestStableVersion or \"n/a\"))\n    infoPanel[#infoPanel + 1] = row(\"📦\", \"Newest Beta\", tostring(info.newestBetaVersion or \"n/a\"))\n  end\n\n  infoPanel[#infoPanel + 1] = SPACER  -- spacer before LED\n\n  -- ── LED Brightness ───────────────────────────────────────────────────\n  local ledBrightness = data.ledBrightness\n  if ledBrightness ~= nil then\n    infoPanel[#infoPanel + 1] = row(\"💡\", \"Hub LED Brightness\", string.format(\"%d%%\", toNum(ledBrightness)))\n  else\n    infoPanel[#infoPanel + 1] = row(\"💡\", \"Hub LED Brightness\", \"n/a\")\n  end\n\n  return infoPanel\nend\n\nfunction QuickApp:buildLines(data)\n  local cpuPanel = {}\n  local infoPanel = self:buildInfoPanel(data)\n  local networkPanel = {}\n  local cpuLines = {}\n\n  cpuPanel[#cpuPanel + 1] = title(\"CPU Info\")\n\n  -- ── CPU ──────────────────────────────────────────────────────────────\n  local cpuNow = data.cpuLoad\n  local avgPct = nil\n\n  if not cpuNow or #cpuNow == 0 then\n    cpuLines[#cpuLines + 1] = row(\"🖥️\", \"CPU\", \"n/a\")\n  elseif not self.prevCpu then\n    self.prevCpu = cpuNow\n    cpuLines[#cpuLines + 1] = row(\"🖥️\", \"CPU\", \"waiting for 2nd sample...\")\n  else\n    local totalPct = 0\n    local count    = math.min(#cpuNow, #self.prevCpu)\n\n    for i = 1, count do\n      local pct = round1(calcCpuPercent(self.prevCpu[i], cpuNow[i]))\n      totalPct = totalPct + pct\n      local name = cpuNow[i].name or (\"cpu\" .. (i - 1))\n      cpuLines[#cpuLines + 1] = row(\"🖥️\", name, string.format(\"%.1f%%\", pct))\n    end\n\n    self.prevCpu = cpuNow\n    avgPct = round1(totalPct / count)\n    rbPush(self.cpuHistory, avgPct)\n\n    self.avgSnapshot = buildAvgSnapshot(self, avgPct)\n  end\n\n  for _, avgLine in ipairs(buildAvgRows(self.avgSnapshot)) do\n    cpuPanel[#cpuPanel + 1] = avgLine\n  end\n  if #cpuPanel > 0 then cpuPanel[#cpuPanel + 1] = SPACER end\n  for _, cpuLine in ipairs(cpuLines) do\n    cpuPanel[#cpuPanel + 1] = cpuLine\n  end\n\n  cpuPanel[#cpuPanel + 1] = SPACER  -- spacer before memory\n\n  -- ── Memory ───────────────────────────────────────────────────────────\n  local mem = data.memory\n  if not mem then\n    cpuPanel[#cpuPanel + 1] = row(\"💾\", \"Memory\", \"n/a\")\n  else\n    local memNotUsed = math.max(0, round1(100 - toNum(mem.used) - toNum(mem.cache) - toNum(mem.buffers)))\n    cpuPanel[#cpuPanel + 1] = row(\"💾\", \"MEM used\",    string.format(\"%.1f%%\", toNum(mem.used)))\n    cpuPanel[#cpuPanel + 1] = row(\"💾\", \"MEM free\",    string.format(\"%.1f%%\", toNum(mem.free)))\n    cpuPanel[#cpuPanel + 1] = row(\"💾\", \"MEM cache\",   string.format(\"%.1f%%\", toNum(mem.cache)))\n    cpuPanel[#cpuPanel + 1] = row(\"💾\", \"MEM buffers\", string.format(\"%.1f%%\", toNum(mem.buffers)))\n    cpuPanel[#cpuPanel + 1] = row(\"💾\", \"MEM not used\", string.format(\"%.1f%%\", memNotUsed))\n  end\n\n  cpuPanel[#cpuPanel + 1] = SPACER  -- spacer before storage\n\n  -- ── Storage ──────────────────────────────────────────────────────────\n  local storage = data.storage\n  if not storage or not storage.internal or #storage.internal == 0 then\n    cpuPanel[#cpuPanel + 1] = row(\"💿\", \"Storage\", \"n/a\")\n  else\n    for _, disk in ipairs(storage.internal) do\n      cpuPanel[#cpuPanel + 1] = row(\"💿\", disk.name or \"disk\", string.format(\"%.1f%%\", toNum(disk.used)))\n    end\n  end\n\n  cpuPanel[#cpuPanel + 1] = SPACER  -- spacer before QA self-stats\n\n  -- ── This QuickApp ────────────────────────────────────────────────────\n  local hubDate = data.settingsInfo and data.settingsInfo.date or \"n/a\"\n  cpuPanel[#cpuPanel + 1] = row(\"🕐\", \"Hub Time\", tostring(hubDate))\n  local qaCpuPct = sampleThisQaCpu(self)\n  local luaKB = collectgarbage(\"count\")\n  cpuPanel[#cpuPanel + 1] = row(\"⚙️\", \"This QA — Loop interval\", string.format(\"%.0f s\", POLL_S))\n  cpuPanel[#cpuPanel + 1] = row(\"⚙️\", \"This QA — CPU\", qaCpuPct and string.format(\"%.3f%%\", qaCpuPct) or \"waiting...\")\n  cpuPanel[#cpuPanel + 1] = row(\"⚙️\", \"This QA — Lua mem\", string.format(\"%.1f kB\", luaKB))\n\n  -- ── Network ──────────────────────────────────────────────────────────\n  networkPanel[#networkPanel + 1] = title(\"Network\")\n\n  local net = data.networkConfig\n  if not net then\n    networkPanel[#networkPanel + 1] = row(\"🌐\", \"Network\", \"n/a\")\n  else\n    local eth0 = net.eth0\n    if eth0 and eth0.ipConfig then\n      networkPanel[#networkPanel + 1] = row(\"🔌\", \"Ethernet IP\", tostring(eth0.ipConfig.ip or \"n/a\"))\n      networkPanel[#networkPanel + 1] = row(\"🔌\", \"Ethernet MAC\", tostring(eth0.ipConfig.macAddress or \"n/a\"))\n    end\n\n    networkPanel[#networkPanel + 1] = SPACER\n\n    local wlan0 = net.wlan0\n    if wlan0 and wlan0.ipConfig then\n      networkPanel[#networkPanel + 1] = row(\"📶\", \"Main Wifi IP\", tostring(wlan0.ipConfig.ip or \"n/a\"))\n      networkPanel[#networkPanel + 1] = row(\"📶\", \"Main Wifi MAC\", tostring(wlan0.ipConfig.macAddress or \"n/a\"))\n    end\n\n    networkPanel[#networkPanel + 1] = SPACER\n\n    local wlan1 = net.wlan1\n    if wlan1 and wlan1.ipConfig then\n      networkPanel[#networkPanel + 1] = row(\"📶\", \"Backup Wifi IP\", tostring(wlan1.ipConfig.ip or \"n/a\"))\n      networkPanel[#networkPanel + 1] = row(\"📶\", \"Backup Wifi MAC\", tostring(wlan1.ipConfig.macAddress or \"n/a\"))\n    end\n  end\n\n  -- ── Local Access ─────────────────────────────────────────────────────\n  networkPanel[#networkPanel + 1] = SPACER\n  networkPanel[#networkPanel + 1] = SEPARATOR\n  networkPanel[#networkPanel + 1] = title(\"Local Access\")\n\n  local serial = data.settingsInfo and data.settingsInfo.serialNumber or \"HC3-00000000\"\n  local serialLower = string.lower(serial)\n  local ethIp = data.networkConfig and data.networkConfig.eth0\n    and data.networkConfig.eth0.ipConfig and data.networkConfig.eth0.ipConfig.ip\n\n  networkPanel[#networkPanel + 1] = linkRow(\n    \"🔍\",\n    \"Find Gateways\",\n    \"https://find.fibaro.com\",\n    \"URL to find hubs on your local Network /LAN\"\n  )\n  networkPanel[#networkPanel + 1] = SPACER\n  networkPanel[#networkPanel + 1] = linkRow(\n    \"🔗\",\n    \"mDNS login\",\n    string.format(\"http://%s.local\", serialLower),\n    \"URL to access this Hub if you are on the same Network /LAN with Multicast DNS\"\n  )\n  networkPanel[#networkPanel + 1] = SPACER\n  networkPanel[#networkPanel + 1] = linkRow(\n    \"🔗\",\n    \"IP Login\",\n    string.format(\"http://%s/login\", tostring(ethIp or \"n/a\")),\n    \"URL to access this Hub if you are on the same Network /LAN with the IP.\"\n  )\n  networkPanel[#networkPanel + 1] = SPACER\n  networkPanel[#networkPanel + 1] = string.format(\n    \"<tr><td colspan='2' align='left'><font color='%s'><i>Remember to use Local user and password!</i></font></td></tr>\",\n    C_LABEL\n  )\n\n  -- ── Remote Access ────────────────────────────────────────────────────\n  networkPanel[#networkPanel + 1] = SPACER\n  networkPanel[#networkPanel + 1] = SEPARATOR\n  networkPanel[#networkPanel + 1] = title(\"Remote Access\")\n  networkPanel[#networkPanel + 1] = linkRow(\n    \"☁️\",\n    \"Yubii ID\",\n    \"https://id.cloud.fibaro.com/\",\n    \"URL for Remote Access with Yubii ID\"\n  )\n\n  -- ── Fibaro Support ──────────────────────────────────────────────────\n  networkPanel[#networkPanel + 1] = SPACER\n  networkPanel[#networkPanel + 1] = SEPARATOR\n  networkPanel[#networkPanel + 1] = title(\"Fibaro Support\")\n  networkPanel[#networkPanel + 1] = linkRow(\"🛟\", \"Support\", \"https://www.fibaro.com/en/support/\")\n  networkPanel[#networkPanel + 1] = linkRow(\"📖\", \"Manual\", \"https://manuals.fibaro.com/home-center-3/\")\n\n  -- ── Users ────────────────────────────────────────────────────────────\n  local usersPanel = {}\n  usersPanel[#usersPanel + 1] = title(\"Users\")\n\n  local users = data.users or {}\n  local normalUsers = {}\n  local installerUsers = {}\n  for _, user in ipairs(users) do\n    if tostring(user.type) == \"installer\" then\n      table.insert(installerUsers, user)\n    else\n      table.insert(normalUsers, user)\n    end\n  end\n\n  -- Build userMap early so it's available for mobile devices\n  local userMap = {}\n  for _, u in ipairs(users) do\n    userMap[u.id] = u.name\n  end\n\n  if #users > 0 then\n    usersPanel[#usersPanel + 1] = row(\"👥\", \"Total Users\", tostring(#users))\n  end\n\n  if #normalUsers == 0 then\n    usersPanel[#usersPanel + 1] = row(\"👤\", \"Users\", \"n/a\")\n  else\n    for i, user in ipairs(normalUsers) do\n      if i > 1 then\n        usersPanel[#usersPanel + 1] = SPACER\n        usersPanel[#usersPanel + 1] = SEPARATOR\n      end\n      usersPanel[#usersPanel + 1] = row(\"👤\", \"Name\", tostring(user.name or \"n/a\"))\n      usersPanel[#usersPanel + 1] = row(\"🆔\", \"ID\", tostring(user.id or \"n/a\"))\n      usersPanel[#usersPanel + 1] = row(\"🔑\", \"Type\", tostring(user.type or \"n/a\"))\n      usersPanel[#usersPanel + 1] = row(\"📧\", \"Email\", tostring(user.email or \"n/a\"))\n      usersPanel[#usersPanel + 1] = row(\"🏠\", \"At Home\", tostring(user.atHome or false))\n      usersPanel[#usersPanel + 1] = row(\"☁️\", \"RA Status\", tostring(user.raStatus or \"n/a\"))\n      usersPanel[#usersPanel + 1] = row(\"🔗\", \"Fibaro ID Role\", tostring(user.fidRole or \"n/a\"))\n      usersPanel[#usersPanel + 1] = row(\"🔔\", \"Notifications\", tostring(user.sendNotifications or false))\n      usersPanel[#usersPanel + 1] = row(\"🎨\", \"Skin\", tostring(user.skin or \"n/a\"))\n      usersPanel[#usersPanel + 1] = row(\"🎨\", \"Skin Setting\", tostring(user.skinSetting or \"n/a\"))\n      usersPanel[#usersPanel + 1] = row(\"🔐\", \"Optional Arm Pin\", tostring(user.useOptionalArmPin or false))\n      usersPanel[#usersPanel + 1] = row(\"🔐\", \"Integration Pin\", tostring(user.useIntegrationPin or false))\n      usersPanel[#usersPanel + 1] = row(\"📜\", \"TOS Accepted\", tostring(user.tosAccepted or false))\n      usersPanel[#usersPanel + 1] = row(\"🔒\", \"Privacy Accepted\", tostring(user.privacyPolicyAccepted or false))\n\n      -- Rights\n      if user.rights then\n        usersPanel[#usersPanel + 1] = SPACER\n        usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Rights - Devices All\", tostring(user.rights.devices and user.rights.devices.all or false))\n        usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Rights - Scenes All\", tostring(user.rights.scenes and user.rights.scenes.all or false))\n        usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Rights - Alarm All\", tostring(user.rights.alarmPartitions and user.rights.alarmPartitions.all or false))\n        usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Rights - Profiles All\", tostring(user.rights.profiles and user.rights.profiles.all or false))\n        usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Rights - Climate All\", tostring(user.rights.climateZones and user.rights.climateZones.all or false))\n        if user.rights.advanced then\n          usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Adv - Devices\", tostring(user.rights.advanced.devices or false))\n          usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Adv - Rooms\", tostring(user.rights.advanced.rooms or false))\n          usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Adv - Scenes\", tostring(user.rights.advanced.blockScenes or false))\n          usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Adv - Scenarios\", tostring(user.rights.advanced.scenarios or false))\n          usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Adv - Profiles\", tostring(user.rights.advanced.profiles or false))\n          usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Adv - Vars/Events\", tostring(user.rights.advanced.variablesAndEvents or false))\n          usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Adv - Access\", tostring(user.rights.advanced.access or false))\n          usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Adv - Update\", tostring(user.rights.advanced.update or false))\n          usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Adv - Backup\", tostring(user.rights.advanced.backup or false))\n          usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Adv - Network\", tostring(user.rights.advanced.network or false))\n          usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Adv - Diagnostics\", tostring(user.rights.advanced.diagnostics or false))\n          usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Adv - Z-Wave\", tostring(user.rights.advanced.zWave or false))\n          usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Adv - Nice/Elero\", tostring(user.rights.advanced.niceAndElero or false))\n          usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Adv - Climate\", tostring(user.rights.advanced.climate or false))\n          usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Adv - Alarm\", tostring(user.rights.advanced.alarm or false))\n          usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Adv - Garden\", tostring(user.rights.advanced.garden or false))\n          usersPanel[#usersPanel + 1] = row(\"⚙️\", \"Adv - KNX\", tostring(user.rights.advanced.knx or false))\n        end\n      end\n    end\n  end\n\n  -- ── Mobile Devices ───────────────────────────────────────────────────\n  usersPanel[#usersPanel + 1] = SPACER\n  usersPanel[#usersPanel + 1] = SEPARATOR\n  usersPanel[#usersPanel + 1] = title(\"Mobile Devices\")\n\n  if data.iosDevices and #data.iosDevices > 0 then\n    usersPanel[#usersPanel + 1] = row(\"📱\", \"Total Devices\", tostring(#data.iosDevices))\n    for _, device in ipairs(data.iosDevices) do\n      local details = getStoredDeviceDetails(data.deviceDetails, device.id)\n      local deviceId = (details and details.id) or device.id or \"n/a\"\n      usersPanel[#usersPanel + 1] = row(\"📱\", \"Device Name\", device.name or \"n/a\")\n      usersPanel[#usersPanel + 1] = row(\"\", \"Device ID\", tostring(deviceId))\n      usersPanel[#usersPanel + 1] = row(\"\", \"Push\", tostring(device.push or false))\n      if details and details.properties then\n        local props = details.properties\n        local appId = props.appId or \"n/a\"\n        if appId == \"com.niceforyou.yubii\" then appId = \"Yubii Home\" end\n        usersPanel[#usersPanel + 1] = row(\"\", \"App ID\", appId)\n        local lastUserId = props.lastLoggedUser\n        local userName = (userMap and userMap[lastUserId]) or \"n/a\"\n        usersPanel[#usersPanel + 1] = row(\"\", \"User Logged\", userName)\n        usersPanel[#usersPanel + 1] = row(\"\", \"System\", props.system or \"n/a\")\n      end\n      usersPanel[#usersPanel + 1] = SPACER\n    end\n  else\n    usersPanel[#usersPanel + 1] = row(\"📱\", \"Mobile Devices\", \"n/a\")\n  end\n\n  -- installer users will be rendered in the installer panel below\n\n\n  -- ── Installer Access ────────────────────────────────────────────────\n  local installerPanel = {}\n  installerPanel[#installerPanel + 1] = title(\"Installer Access\")\n\n  local instAccess = data.installerAccess\n  if not instAccess then\n    installerPanel[#installerPanel + 1] = row(\"🔧\", \"Installer Access\", \"n/a\")\n  else\n    local enabled = instAccess.installationAccess or false\n    local enabledIcon = enabled and \"✅\" or \"❌\"\n    installerPanel[#installerPanel + 1] = row(enabledIcon, \"Access Enabled\", tostring(enabled))\n    installerPanel[#installerPanel + 1] = row(\"🕒\", \"Expire Time\", instAccess.installationAccessExpireTime and os.date(\"%Y-%m-%d %H:%M:%S\", instAccess.installationAccessExpireTime) or \"n/a\")\n    if enabled and instAccess.installationAccessExpireTime then\n      local expireTime = tonumber(instAccess.installationAccessExpireTime) or 0\n      if expireTime > 0 then\n        local remaining = expireTime - os.time()\n        if remaining > 0 then\n          local hours = math.floor(remaining / 3600)\n          local mins = math.floor((remaining % 3600) / 60)\n          installerPanel[#installerPanel + 1] = row(\"⏱️\", \"Expires in\", string.format(\"%dh %dm\", hours, mins))\n        else\n          installerPanel[#installerPanel + 1] = row(\"⏱️\", \"Status\", \"Expired\")\n        end\n      end\n    end\n  end\n\n  local installerInfo = data.installerInfo\n  if installerInfo then\n    installerPanel[#installerPanel + 1] = SPACER\n    installerPanel[#installerPanel + 1] = row(\"📧\", \"Installer Email\", tostring(installerInfo.email or \"n/a\"))\n    installerPanel[#installerPanel + 1] = row(\"👤\", \"Installer Name\", tostring((installerInfo.firstName or \"\") .. \" \" .. (installerInfo.lastName or \"\")))\n    installerPanel[#installerPanel + 1] = row(\"🛡️\", \"Certified\", tostring(installerInfo.isCertified or false))\n    installerPanel[#installerPanel + 1] = row(\"🔄\", \"Synchronized\", tostring(installerInfo.isSynchronized or false))\n    installerPanel[#installerPanel + 1] = row(\"🌐\", \"Remote Access\", tostring(installerInfo.remoteAccess or false))\n    installerPanel[#installerPanel + 1] = row(\"📊\", \"Monitoring\", tostring(installerInfo.monitoring or false))\n  end\n\n  installerPanel[#installerPanel + 1] = SPACER\n  installerPanel[#installerPanel + 1] = row(\"⏳\", \"Remote Access Granted\", self.installerGrantedAt and os.date(\"%Y-%m-%d %H:%M:%S\", self.installerGrantedAt) or \"n/a\")\n  installerPanel[#installerPanel + 1] = row(\"⏱\", \"Remote Access Expires\", self.installerExpiresAt and os.date(\"%Y-%m-%d %H:%M:%S\", self.installerExpiresAt) or \"n/a\")\n  installerPanel[#installerPanel + 1] = row(\"🚫\", \"Remote Access Withdrawn\", self.installerWithdrawnAt and os.date(\"%Y-%m-%d %H:%M:%S\", self.installerWithdrawnAt) or \"n/a\")\n\n  if #installerUsers > 0 then\n    installerPanel[#installerPanel + 1] = SPACER\n    for _, user in ipairs(installerUsers) do\n      installerPanel[#installerPanel + 1] = SPACER\n      installerPanel[#installerPanel + 1] = row(\"👤\", \"Name\", tostring(user.name or \"n/a\"))\n      installerPanel[#installerPanel + 1] = row(\"🆔\", \"ID\", tostring(user.id or \"n/a\"))\n      installerPanel[#installerPanel + 1] = row(\"🔑\", \"Type\", tostring(user.type or \"n/a\"))\n      installerPanel[#installerPanel + 1] = row(\"📧\", \"Email\", tostring(user.email or \"n/a\"))\n      installerPanel[#installerPanel + 1] = row(\"🏠\", \"At Home\", tostring(user.atHome or false))\n      installerPanel[#installerPanel + 1] = row(\"☁️\", \"RA Status\", tostring(user.raStatus or \"n/a\"))\n      installerPanel[#installerPanel + 1] = row(\"🔗\", \"Fibaro ID Role\", tostring(user.fidRole or \"n/a\"))\n      installerPanel[#installerPanel + 1] = row(\"🔔\", \"Notifications\", tostring(user.sendNotifications or false))\n      installerPanel[#installerPanel + 1] = row(\"🎨\", \"Skin\", tostring(user.skin or \"n/a\"))\n    end\n  end\n\n  -- Credential status message\n  local username = tostring(self:getVariable(\"Username\") or \"\")\n  local password = tostring(self:getVariable(\"Password\") or \"\")\n  if username == \"\" or password == \"\" then\n    installerPanel[#installerPanel + 1] = SPACER\n    installerPanel[#installerPanel + 1] = string.format(\n      \"<tr><td colspan='2' align='center'><font color='%s' size='3'><b>%s</b></font></td></tr>\",\n      C_RED, \"Username and Password isnt set and cant grant access for installers without it from this Quickapp!\"\n    )\n  elseif self.credentialError then\n    installerPanel[#installerPanel + 1] = SPACER\n    installerPanel[#installerPanel + 1] = string.format(\n      \"<tr><td colspan='2' align='center'><font color='%s' size='3'><b>%s</b></font></td></tr>\",\n      C_RED, \"Credentials isn't right or something.\"\n    )\n  else\n    installerPanel[#installerPanel + 1] = SPACER\n    installerPanel[#installerPanel + 1] = string.format(\n      \"<tr><td colspan='2' align='center'><font color='%s' size='3'><b>%s</b></font></td></tr>\",\n      C_GREEN, \"Username and password are set try to grant access for Installer:\"\n    )\n  end\n\n  return cpuPanel, infoPanel, networkPanel, usersPanel, installerPanel, avgPct\nend\n\nfunction QuickApp:pollDiagnostics()\n  local ok, data = pcall(function() return api.get(\"/diagnostics\") end)\n\n  if not ok or not data then\n    self:error(\"Failed to read /diagnostics\")\n    self:updateView(\"Info\", \"text\", renderHtml({ row(\"❗\", \"Error\", \"Failed to read /diagnostics\") }))\n    setTimeout(function() self:pollDiagnostics() end, POLL_MS)\n    return\n  end\n\n  -- Merge with static data\n  if self.staticData then\n    for k, v in pairs(self.staticData) do\n      data[k] = v\n    end\n  end\n\n  local cpuPanel, infoPanel, networkPanel, usersPanel, installerPanel, avgPct = self:buildLines(data)\n\n  -- add 200 blank lines to the dedicated \"space\" label control\n  local blankLines = string.rep(\"\\n\", 200)\n  self:updateView(\"space\", \"text\", blankLines)\n\n  self:updateView(\"info_cpu\", \"text\", renderHtml(cpuPanel))\n  self:updateView(\"Info\", \"text\", renderHtml(infoPanel))\n  self:updateView(\"info_localaccess\", \"text\", renderHtml(networkPanel))\n  self:updateView(\"info_users\", \"text\", renderHtml(usersPanel))\n  self:updateView(\"info_installer\", \"text\", renderHtml(installerPanel))\n\n  if data.ledBrightness ~= nil then\n    refreshLedBrightnessSlider(self, data.ledBrightness)\n  end\n\n  local remoteAccessEnabled = data.installerInfo and data.installerInfo.remoteAccess or false\n  refreshInstallerAccessButton(self, remoteAccessEnabled)\n\n  if avgPct then\n    self:updateProperty(\"value\", avgPct)\n    local avg1h = self.avgSnapshot and self.avgSnapshot.avg1h\n    if avg1h then\n      self:updateProperty(\"log\", string.format(\"1h avg: %.1f%%\", round1(avg1h)))\n    else\n      self:updateProperty(\"log\", string.format(\"CPU avg: %.1f%%\", avgPct))\n    end\n  end\n  persistCpuState(self)\n\n  self.currentData = data\n\n  setTimeout(function() self:pollDiagnostics() end, POLL_MS)\nend\n\nfunction QuickApp:led_brightness(event)\n  local value = tonumber(event.values[1]) or 0\n  local previousValue = self.currentData and self.currentData.ledBrightness\n  if previousValue == nil and self.staticData then\n    previousValue = self.staticData.ledBrightness\n  end\n  value = math.max(0, math.min(100, math.floor(value)))\n  refreshLedBrightnessSlider(self, value)\n  local ok, err = pcall(function() api.put(\"/settings/led\", { brightness = value }) end)\n  if ok then\n    self:debug(string.format(\"LED brightness set to %d%%\", value))\n    -- Verify after 1 second delay\n    setTimeout(function()\n      local ok2, led = pcall(function() return api.get(\"/settings/led\") end)\n      if ok2 and type(led) == \"table\" then\n        refreshLedBrightnessSlider(self, led.brightness)\n        self:debug(string.format(\"LED brightness verified: %d%%\", toNum(led.brightness)))\n        -- Update the Info panel label immediately\n        if self.currentData then\n          self.currentData.ledBrightness = led.brightness\n          self:updateView(\"Info\", \"text\", renderHtml(self:buildInfoPanel(self.currentData)))\n        end\n      else\n        self:error(\"Failed to verify LED brightness\")\n      end\n    end, 1000)\n  else\n    if previousValue ~= nil then\n      refreshLedBrightnessSlider(self, previousValue)\n    end\n    self:error(\"Failed to set LED brightness: \" .. tostring(err))\n  end\nend\n\nfunction QuickApp:installer_access24h(event)\n  local currentEnabled = self.installerInfo and self.installerInfo.remoteAccess or false\n  local eventEnabled = parseBoolFromEvent(event)\n  local newEnabled\n  if eventEnabled == nil then\n    newEnabled = not currentEnabled\n  elseif eventEnabled == currentEnabled then\n    -- Button callbacks can echo current value; treat that as a toggle press.\n    newEnabled = not currentEnabled\n  else\n    newEnabled = eventEnabled\n  end\n  setInstallerAccessButtonValue(self, newEnabled)\n\n  local ok, res = pcall(function()\n    return api.put(\"/installer\", { remoteAccess = newEnabled })\n  end)\n\n  if not ok then\n    -- fallback to older path style\n    ok, res = pcall(function()\n      return api.put(\"/api/installer\", { remoteAccess = newEnabled })\n    end)\n  end\n\n  if not ok then\n    setInstallerAccessButtonValue(self, currentEnabled)\n    self:error(\"Failed to set installer remote access (api.put error): \" .. tostring(res))\n    self:error(\"Hint: installer access API may require admin privileges.\")\n    return\n  end\n\n  local statusCode = nil\n  if type(res) == \"table\" and res.status then\n    statusCode = tonumber(res.status)\n  end\n  if statusCode == 401 or statusCode == 403 then\n    self:error(\"Installer access request was unauthorized (\" .. tostring(statusCode) .. \").\")\n    self:error(\"Attempting admin credential fallback...\")\n    self.credentialError = true  -- mark error\n    if requestInstallerAccessWithAdmin(self, newEnabled, currentEnabled) then\n      return\n    end\n    setInstallerAccessButtonValue(self, currentEnabled)\n    self:error(\"Set Username/Password QA variables with an admin account to proceed.\")\n    return\n  end\n\n  -- Some HC3 APIs return no body (nil) on success; that's OK.\n  if res and type(res) == \"table\" and res.remoteAccess ~= nil then\n    self.installerInfo = self.installerInfo or {}\n    self.installerInfo.remoteAccess = res.remoteAccess\n  else\n    self.installerInfo = self.installerInfo or {}\n    self.installerInfo.remoteAccess = newEnabled\n  end\n\n  self.credentialError = false  -- success\n  setInstallerAccessButtonText(self, self.installerInfo.remoteAccess and true or false)\n\n  local now = os.time()\n  if newEnabled then\n    self.installerGrantedAt = now\n    self.installerExpiresAt = now + 24 * 3600\n    self.installerWithdrawnAt = nil\n  else\n    self.installerWithdrawnAt = now\n    self.installerExpiresAt = nil\n  end\n  saveInstallerTimeline(self)\n\n  -- keep settings/installationAccess in sync so \"Access Enabled\" updates correctly\n  syncInstallationAccessState(self, newEnabled, now)\n\n  self:debug(string.format(\"Installer remote access set to %s\", tostring(newEnabled)))\n  setTimeout(function() self:pollDiagnostics() end, 2000)\n  -- Verify access after 10 seconds\n  setTimeout(function() self:fetchStaticData(false) end, 10000)\nend\n\nfunction QuickApp:update(event)\n  if self.updateInProgress then\n    self:debug(\"Manual update already running\")\n    return\n  end\n\n  self.updateInProgress = true\n  self:updateView(\"update\", \"value\", \"true\")\n  self:debug(\"Manual update triggered\")\n  local ok, err = pcall(function()\n    self:fetchStaticData(false)\n    self:fetchZwaveTransmissions()\n    self:pollDiagnostics()\n  end)\n  if not ok then\n    self:error(\"Manual update failed: \" .. tostring(err))\n  end\n\n  self.updateInProgress = false\n  self:updateView(\"update\", \"value\", \"false\")\nend\n"}]}